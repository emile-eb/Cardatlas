# Copy this file to supabase/functions/.env for local development.
CARD_RECOGNITION_PROVIDER=google_gemini
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash
GEMINI_CHAT_MODEL=gemini-2.5-flash
CARDSIGHT_API_URL=https://api.cardsight.example/v1/recognize
CARDSIGHT_API_KEY=your_cardsight_api_key
AI_PREMIUM_MESSAGE_LIMIT=40
AI_BYPASS_PREMIUM=false
AI_MAX_MESSAGE_LENGTH=1200
AI_DUPLICATE_WINDOW_SECONDS=20
AI_RAPID_WINDOW_SECONDS=2
AI_CONTEXT_MESSAGE_COUNT=6
